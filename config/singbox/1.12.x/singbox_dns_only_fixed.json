    },
    {
      "tag": "🧠 AI",
      "type": "selector",
      "outbounds": [
        "🇯🇵 日本自动",
        "🇸🇬 狮城自动",
        "🇺🇲 美国手动"
      ]
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff",
        "sniffer": ["http","tls","quic","dns"]
