  "outbounds": [
    {
      "tag": "🚀 默认代理",
      "type": "selector",
      "outbounds": [
        "🇭🇰 香港自动",
        "🇯🇵 日本自动",
        "🇸🇬 狮城自动",
        "🇺🇲 美国手动",
